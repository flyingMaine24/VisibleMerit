# Visible Merit local/deploy configuration

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=you@example.com

# Feature flags
ENABLE_CHECKOUT=false
ENABLE_PREVIEW_GENERATION=true
ENABLE_FULL_PACK_GENERATION=true
ENABLE_EMAIL_DELIVERY=false

# Persistence
VISIBLE_MERIT_REPOSITORY=local
VISIBLE_MERIT_STORE_PATH=.visible-merit/local-store.json

# Supabase
# Use SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY for the server-side repository.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Resend
RESEND_API_KEY=
FROM_EMAIL=Visible Merit <packs@visiblemerit.com>
